---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FlatCard from "@/components/ui/FlatCard.astro";
import { projects } from "@/data/cards";

const years = [...new Set(projects.map((c) => c.year || 0))].sort((a, b) => b - a);
const grouped = Object.groupBy(projects, (c) => String(c.year || 0));
---

<BaseLayout title="Projects">
  <div class="mx-auto max-w-4xl px-6 py-12">
    <header class="mb-6">
      <h1 class="serif italic text-ink" style="font-size: 28px;">Projects</h1>
      <p class="mt-2 text-ink-3">Apps, demos, and libraries.</p>
    </header>

    <div class="flex flex-col gap-8">
      {years.map((year) => {
        const items = grouped[String(year)] || [];
        if (items.length === 0) return null;
        return (
          <section>
            <h2 class="serif italic text-ink-3 text-sm mb-3">{year}</h2>
            <div class="flex flex-col gap-3">
              {items.map((card) => (
                <FlatCard
                  title={card.title}
                  subtitle={card.subtitle}
                  url={card.url}
                  image={card.image}
                  category={card.category}
                  tags={card.tags}
                  imageClass={card.imageClass}
                />
              ))}
            </div>
          </section>
        );
      })}
    </div>
  </div>
</BaseLayout>
