---
interface Props {
  title: string;
  subtitle: string;
  url: string;
  image: string;
  year?: number;
  category?: string;
  tags?: string[];
  links?: { label: string; url: string }[];
  imageClass?: string;
}

const { title, subtitle, url, image, year, category, tags = [], links = [], imageClass } = Astro.props;
---

<div
  class="group flex items-start gap-5 rounded-xl bg-paper-warm/60 p-5 transition-all hover:bg-paper-warm hover:shadow-lg cursor-pointer"
  data-href={url}
>
  <div class="h-14 w-14 flex-shrink-0 rounded-full overflow-hidden">
    <img
      src={image}
      alt={title}
      class:list={["h-full w-full", imageClass || "object-cover"]}
      loading="lazy"
    />
  </div>
  <div class="flex min-w-0 flex-col gap-1">
    <div class="flex items-baseline gap-2">
      <h3 class="serif text-lg leading-tight text-ink group-hover:text-rust transition-colors">{title}</h3>
      {category && <span class="text-[11px] text-ink-3/60">{category}</span>}
    </div>
    <span class="serif italic text-ink-3 text-[11px]">
      {subtitle}
      {links.map((link) => (
        <> · <a href={link.url} class="text-rust hover:underline">{link.label}</a></>
      ))}
    </span>
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-1">
          {tags.map((tag) => (
            <span class="text-[10px] text-ink-3 font-medium">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-href]').forEach((el) => {
    el.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).tagName === 'A') return;
      window.open(el.dataset.href!, '_blank', 'noopener,noreferrer');
    });
  });
</script>
